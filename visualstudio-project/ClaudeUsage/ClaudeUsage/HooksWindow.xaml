<ui:FluentWindow x:Class="ClaudeUsage.HooksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Claude Code Hooks"
        Width="720"
        SizeToContent="Height"
        MaxHeight="900"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,18,0,8"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="CardDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
        </Style>
        <Style x:Key="PreviewCard" TargetType="Border">
            <Setter Property="Background" Value="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ui:ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border x:Name="HeaderBar" Grid.Row="0" Padding="20,14,12,10"
                Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:SymbolIcon Grid.Column="0" Symbol="PlugConnected24" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Claude Code Hooks" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#3B82F6" CornerRadius="4" Padding="6,1,6,2" Margin="10,2,0,0" VerticalAlignment="Center">
                        <TextBlock Text="BETA" FontSize="9" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#78828C" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Hook server status" FontSize="12"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <ui:Button Grid.Column="4" Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent"
                           Padding="8" ToolTip="Close" Click="CloseButton_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="820" Padding="20,0,20,18">
            <StackPanel>

                <!-- ============ This machine ============ -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="This machine" Margin="2,4,0,8"/>

                <ui:CardControl Icon="{ui:SymbolIcon PlugConnected24}" Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}" Text="Enable real-time hooks"/>
                            <TextBlock Style="{StaticResource CardDesc}" Text="Track Claude Code sessions on this PC. Updates ~/.claude/settings.json."/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="EnableHooksToggle" OnContent="On" OffContent="Off" Click="EnableHooksToggle_Click"/>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon Alert24}" Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}" Text="Toast notifications"/>
                            <TextBlock Style="{StaticResource CardDesc}" Text="Notify when a session finishes or needs your input."/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="ToastToggle" OnContent="On" OffContent="Off" Click="ToastToggle_Click"/>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon Keyboard24}" Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}" Text="Show / hide the widget"/>
                            <TextBlock Style="{StaticResource CardDesc}" Text="Double-tap this key (twice within 400 ms) to toggle the widget from any app."/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#3B82F6" CornerRadius="6" Padding="11,3,11,5" VerticalAlignment="Center">
                            <TextBlock x:Name="HotkeyKeyText" Text="Right Alt" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <ui:Button x:Name="HotkeyEditButton" Icon="{ui:SymbolIcon Edit24}" Appearance="Transparent"
                                   Padding="6" Margin="4,0,12,0" ToolTip="Change key" Click="HotkeyEdit_Click"/>
                        <ui:ToggleSwitch x:Name="HotkeyToggle" OnContent="On" OffContent="Off" Click="HotkeyToggle_Click"/>
                    </StackPanel>
                </ui:CardControl>

                <ui:Button Appearance="Transparent" Margin="0,6,0,0" HorizontalAlignment="Left"
                           Content="Copy hook config (manual setup)" Icon="{ui:SymbolIcon Copy24}" Click="CopyLocalConfig_Click"/>

                <!-- ============ Remote sessions ============ -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="Remote sessions"/>

                <ui:CardControl Icon="{ui:SymbolIcon Globe24}" Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}" Text="Allow remote sessions"/>
                            <TextBlock Style="{StaticResource CardDesc}" Text="SSH, WSL, or another machine. Binds the hook server to all network interfaces (restart required)."/>
                            <TextBlock x:Name="RemoteRestartNote" FontSize="12" Foreground="#E0A030"
                                       Margin="0,3,0,0" Text="Restart ClaudeUsage to apply this change." Visibility="Collapsed"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="RemoteToggle" OnContent="On" OffContent="Off" Click="RemoteToggle_Click"/>
                </ui:CardControl>

                <ui:CardExpander Icon="{ui:SymbolIcon ArrowDownload24}" Margin="0,0,0,4">
                    <ui:CardExpander.Header>
                        <StackPanel>
                            <TextBlock Style="{StaticResource CardTitle}" Text="Set up a remote machine"/>
                            <TextBlock Style="{StaticResource CardDesc}" Text="Run one command on the other machine to install the hook relay."/>
                        </StackPanel>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="0,2,0,2">
                        <TextBlock Style="{StaticResource CardDesc}" Margin="0,0,0,8"
                                   Text="On the remote machine (SSH/WSL), run this command. The relay fails fast when this widget is offline, so it never stalls the session and reconnects on its own."/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InstallCommandBox" Grid.Column="0" IsReadOnly="True"
                                     FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                                     VerticalContentAlignment="Center" Padding="10,8"
                                     Background="{ui:ThemeResource ControlFillColorDefaultBrush}"/>
                            <ui:Button Grid.Column="1" Content="Copy" Icon="{ui:SymbolIcon Copy24}"
                                       Appearance="Primary" Margin="8,0,0,0" VerticalAlignment="Stretch" Click="CopyInstallCommand_Click"/>
                        </Grid>
                        <TextBlock x:Name="HostNote" Style="{StaticResource CardDesc}" Margin="0,8,0,0"/>
                        <ui:Button Appearance="Transparent" Margin="-6,8,0,0" HorizontalAlignment="Left"
                                   Content="No curl? Copy hook config" Icon="{ui:SymbolIcon Copy24}" Click="CopyRemoteConfig_Click"/>
                    </StackPanel>
                </ui:CardExpander>

                <!-- ============ Live widget ============ -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="Live widget"/>

                <Border Style="{StaticResource PreviewCard}" Padding="18,18">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardDesc}" HorizontalAlignment="Center" Margin="0,0,0,14"
                                   Text="Appears on your desktop while Claude Code sessions are active — local and remote together."/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" UseLayoutRounding="True">
                            <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Border.Background><SolidColorBrush Color="#1A1A1A" Opacity="0.95"/></Border.Background>
                                <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.4" Color="Black"/></Border.Effect>
                                <Ellipse x:Name="PreviewCompactA" Width="9" Height="9" Fill="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Border.Background><SolidColorBrush Color="#1A1A1A" Opacity="0.95"/></Border.Background>
                                <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.4" Color="Black"/></Border.Effect>
                                <Ellipse x:Name="PreviewCompactB" Width="9" Height="9" Fill="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <Border CornerRadius="18" Padding="16,9,12,9" VerticalAlignment="Center" SnapsToDevicePixels="True">
                                <Border.Background><SolidColorBrush Color="#1A1A1A" Opacity="0.95"/></Border.Background>
                                <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.45" Color="Black"/></Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="PreviewDot" Width="9" Height="9" Fill="#22C55E" VerticalAlignment="Center" Margin="0,1,9,0"/>
                                    <TextBlock x:Name="PreviewText" VerticalAlignment="Center" Margin="0,-2,0,0">
                                        <Run x:Name="PreviewName" Text="claude-usage" FontSize="12.5" FontWeight="SemiBold" Foreground="White"/>
                                        <Run Text="  ·  " FontSize="12" Foreground="#555"/>
                                        <Run x:Name="PreviewDetail" Text="Editing App.xaml.cs" FontSize="12" Foreground="#999"/>
                                        <Run x:Name="PreviewSep" Text="  ·  " FontSize="12" Foreground="#555"/>
                                        <Run x:Name="PreviewElapsed" Text="1m 12s" FontSize="12" Foreground="#666"/>
                                    </TextBlock>
                                    <Border Margin="8,0,0,0" CornerRadius="10" Width="18" Height="18" VerticalAlignment="Center">
                                        <TextBlock Text="&#x2715;" FontSize="9" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Feedback -->
                <TextBlock x:Name="CopyFeedback" FontSize="12" Foreground="#52D17C"
                           TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"
                           Margin="0,12,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
