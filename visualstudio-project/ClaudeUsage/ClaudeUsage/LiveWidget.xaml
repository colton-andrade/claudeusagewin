<Window x:Class="ClaudeUsage.LiveWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Code Status"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <!-- Outer container: compact circles + expanded pill side by side -->
    <StackPanel Orientation="Horizontal"
                Margin="14"
                VerticalAlignment="Center"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">

        <!-- Compact session circles (separate dark bubbles, populated in code-behind) -->
        <StackPanel x:Name="CompactDotsPanel"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"/>

        <!-- Expanded session pill -->
        <Border CornerRadius="18"
                Padding="16,9,12,9"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
            <Border.Background>
                <SolidColorBrush Color="#1A1A1A" Opacity="0.95"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.45" Color="Black"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal">
                <!-- Status dot -->
                <Ellipse x:Name="StatusDot"
                         Width="9" Height="9"
                         Fill="#22C55E"
                         VerticalAlignment="Center"
                         Margin="0,1,9,0"/>

                <!-- Detail text -->
                <TextBlock VerticalAlignment="Center"
                           Margin="0,-2,0,0">
                    <Run x:Name="StatusRun"
                         Text="Claude Code"
                         FontSize="12.5" FontWeight="SemiBold"
                         Foreground="White"/>
                    <Run Text="  ·  " FontSize="12" Foreground="#555"/>
                    <Run x:Name="DetailRun"
                         Text="Thinking..."
                         FontSize="12"
                         Foreground="#999"/>
                    <Run x:Name="SeparatorRun"
                         Text="  ·  " FontSize="12" Foreground="#555"/>
                    <Run x:Name="ElapsedRun"
                         Text="0s"
                         FontSize="12"
                         Foreground="#666"/>
                </TextBlock>

                <!-- Close -->
                <Border Margin="8,0,0,0"
                        CornerRadius="10" Width="18" Height="18"
                        Background="Transparent"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        MouseLeftButtonUp="CloseButton_Click">
                    <TextBlock Text="&#x2715;" FontSize="9" Foreground="#555"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
